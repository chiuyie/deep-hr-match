# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional: direct Postgres URL for applying migrations (Supabase -> Project Settings -> Database)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Bootstrap first admin (used by npm run create-admin)
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=change-me-8chars-min
ADMIN_NAME=Platform Admin

# Demo seed scripts (optional)
# EMPLOYER_EMAIL=employer@example.com
# DUMMY_USER_PASSWORD=DemoUser123!

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# External matching engine (optional — unset uses inline placeholder)
# MATCHING_ENGINE_URL=https://matching.yourdomain.com
# MATCHING_ENGINE_API_KEY=your-shared-secret
